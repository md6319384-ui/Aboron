rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: products
    // Document ID: productId
    // Fields:
    //   - name: string (required)
    //   - description: string (optional)
    //   - price: number (required)
    //   - image: string (required)
    //   - category: string (required)
    //   - rating: number (optional)
    //   - reviews: number (optional)
    //   - stock: number (required)
    //
    // Collection: orders
    // Document ID: orderId
    // Fields:
    //   - userId: string (required)
    //   - items: list (required)
    //   - total: number (required)
    //   - status: string (required, enum: pending, processing, shipped, delivered)
    //   - createdAt: timestamp (required)
    //   - shippingAddress: string (required)
    //   - trackingNumber: string (optional)
    //
    // Collection: users
    // Document ID: userId
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string (optional)
    //   - role: string (required, enum: admin, customer)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          request.auth.token.email == "md6319384@gmail.com");
    }

    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.price is number && data.price >= 0 &&
             data.image is string && data.image.size() > 0 &&
             data.category is string &&
             data.stock is number && data.stock >= 0;
    }

    function isValidOrder(data) {
      return (data.userId == request.auth.uid || data.userId.matches("^guest_.*")) &&
             data.items is list && data.items.size() > 0 &&
             data.total is number && data.total >= 0 &&
             data.status in ['pending', 'processing', 'shipped', 'delivered'] &&
             data.shippingAddress is string && data.shippingAddress.size() > 0;
    }

    function isValidUser(data) {
      return data.uid == request.auth.uid &&
             data.email is string &&
             data.role in ['admin', 'customer'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /products/{productId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidProduct(request.resource.data);
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if (isAuthenticated() && (isOwner(resource.data.userId) || isAdmin())) || (resource.data.userId.matches("^guest_.*"));
      allow create: if isValidOrder(request.resource.data);
      allow update: if isAdmin();
      allow delete: if false;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == 'customer';
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == resource.data.role;
      allow delete: if false;
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
